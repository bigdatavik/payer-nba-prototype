# Environment variables for local development and testing
# Copy this to .env and fill in values

# Databricks Workspace
DATABRICKS_HOST=https://fevm-serverless-mwelio-humana.cloud.databricks.com
DATABRICKS_TOKEN=your_token_here

# Unity Catalog
CATALOG=humana_payer
SCHEMA=next_best_action

# Lakebase Configuration
LAKEBASE_INSTANCE_UID=2ba1a370-4b04-4ead-b734-3127ea5d66ec
LAKEBASE_DATABASE=projects/lakebase-demo-autoscale
LAKEBASE_SCHEMA=next_best_action_ps

# PostgreSQL Connection (for Lakebase)
# These are auto-injected by Databricks Apps
# For local testing, get from Lakebase connection info
PGHOST=your_lakebase_host
PGDATABASE=databricks_postgres
PGUSER=your_username
PGPASSWORD=your_password
PGPORT=5432

# SQL Warehouse (for queries)
WAREHOUSE_ID=your_warehouse_id
